    <p id="learn-counter">第 1 / 20 个单词</p>
  </div>
  
  <div class="word-card" id="word-card">
    <div class="word-english" id="learn-word"></div>
    <div class="word-phonetic" id="learn-phonetic"></div>
    <div class="word-meaning word-hidden" id="learn-meaning" onclick="revealMeaning()"></div>
    <div class="word-example word-hidden" id="learn-example" onclick="revealMeaning()"></div>
    <div class="schedule-display" id="learn-schedule"></div>
  </div>
  
  <div class="action-buttons">
    <button class="btn btn-danger" onclick="rateWord(1)">😰 完全忘记</button>
    <button class="btn btn-warning" onclick="rateWord(2)">😐 模糊</button>
    <button class="btn btn-success" onclick="rateWord(3)">😊 记得</button>
    <button class="btn btn-primary" onclick="rateWord(4)">😎 熟练</button>
  </div>
  
  <button class="btn btn-outline" onclick="switchPage('home')" style="width:100%;margin-top:8px;">
    ← 返回首页
  </button>
</div>

<!-- Dictation Page -->
<div class="page" id="page-dictation">
  <div class="header">
    <h1>✏️ 默写模式</h1>
    <p id="dictation-counter">第 1 / 20 个单词</p>
  </div>
  
  <div class="word-card">
    <div class="word-meaning" id="dict-meaning" style="font-size:24px;"></div>
    <div class="word-phonetic" id="dict-phonetic" style="margin-top:8px;"></div>
    <div style="margin-top:20px;">
      <input type="text" class="dictation-input" id="dict-input" 
             placeholder="输入英文单词..." autocomplete="off" autocorrect="off" autocapitalize="off">
    </div>
    <div id="dict-feedback" style="min-height:24px;font-size:16px;margin-bottom:12px;"></div>
  </div>
  
  <div style="display:flex;gap:10px;margin-bottom:12px;">
    <button class="btn btn-outline" onclick="showDictHint()" style="flex:1;">💡 提示</button>
    <button class="btn btn-primary" onclick="checkDictation()" style="flex:2;">确认</button>
  </div>
  <button class="btn btn-success" onclick="nextDictation()" style="width:100%;margin-bottom:8px;">
    下一个 →
  </button>
  <button class="btn btn-outline" onclick="switchPage('home')" style="width:100%;">
    ← 返回首页
  </button>
</div>

<!-- Word List Page -->
<div class="page" id="page-list">
  <div class="header">
    <h1>📋 词库管理</h1>
  </div>
  
  <input type="text" class="search-bar" id="search-input" placeholder="🔍 搜索单词..." oninput="filterWords()">
  
  <div class="category-tags" id="category-tags"></div>
  
  <div id="word-list-container"></div>
</div>

<!-- Settings Page -->
<div class="page" id="page-settings">
  <div class="header">
    <h1>⚙️ 设置</h1>
  </div>
  
  <div class="setting-group">
    <div class="setting-item">
      <span class="setting-label">每日新词数量</span>
      <span class="setting-value" id="daily-new-value">15</span>
    </div>
    <div class="setting-item">
      <span class="setting-label">每日复习上限</span>
      <span class="setting-value" id="daily-review-value">50</span>
    </div>
  </div>
  
  <div class="setting-group">
    <div class="setting-item">
      <span class="setting-label">发音辅助</span>
      <div class="toggle active" id="toggle-pronunciation" onclick="toggleSetting(this)"></div>
    </div>
    <div class="setting-item">
      <span class="setting-label">自动翻页</span>
      <div class="toggle" id="toggle-auto-flip" onclick="toggleSetting(this)"></div>
    </div>
  </div>
  
  <div class="setting-group">
    <div class="setting-item" style="cursor:pointer;" onclick="exportData()">
      <span class="setting-label">导出数据</span>
      <span class="setting-value">→</span>
    </div>
    <div class="setting-item" style="cursor:pointer;" onclick="importData()">
      <span class="setting-label">导入数据</span>
      <span class="setting-value">→</span>
    </div>
    <div class="setting-item" style="cursor:pointer;color:var(--danger);" onclick="resetAll()">
      <span class="setting-label">重置所有数据</span>
      <span class="setting-value">→</span>
    </div>
  </div>
  
  <div style="text-align:center;margin-top:24px;color:var(--subtext);font-size:12px;">
    智能背单词 v1.0 | 艾宾浩斯记忆曲线
  </div>
</div>

