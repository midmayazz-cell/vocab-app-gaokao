  renderCategoryTags();
  renderWordList();
}

function loadState() {
  try {
    const saved = localStorage.getItem('vocabAppState');
    if (saved) {
      appState = {...appState, ...JSON.parse(saved)};
    }
  } catch(e) { console.log('Load state error:', e); }
}

function saveState() {
  try {
    localStorage.setItem('vocabAppState', JSON.stringify(appState));
  } catch(e) { console.log('Save state error:', e); }
}

// ==================== 连续学习天数 ====================
function updateStreak() {
  const today = new Date().toDateString();
  const yesterday = new Date(Date.now() - 86400000).toDateString();
  
  if (appState.lastStudyDate === today) return;
  if (appState.lastStudyDate === yesterday) {
    appState.streak++;
  } else if (appState.lastStudyDate !== today) {
    appState.streak = 0;
  }
  saveState();
}

function recordStudy() {
  const today = new Date().toDateString();
  if (appState.lastStudyDate !== today) {
    const yesterday = new Date(Date.now() - 86400000).toDateString();
    if (appState.lastStudyDate === yesterday || !appState.lastStudyDate) {
      appState.streak++;
    } else {
      appState.streak = 1;
    }
    appState.lastStudyDate = today;
    saveState();
  }
}

// ==================== 页面切换 ====================
function switchPage(pageName) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  
  document.getElementById(`page-${pageName}`).classList.add('active');
  document.querySelectorAll('.nav-item')[['home','learn','dictation','list','settings'].indexOf(pageName)]?.classList.add('active');
  
  if (pageName === 'home') renderHomePage();
  if (pageName === 'list') renderWordList();
}

// ==================== Toast提示 ====================
function showToast(message) {
  const toast = document.getElementById('toast');
  toast.textContent = message;
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 2000);
}

// ==================== 首页渲染 ====================
function renderHomePage() {
  const total = WORD_DATABASE.length;
  const learned = Object.keys(appState.wordProgress).length;
  const mastered = Object.values(appState.wordProgress).filter(w => w.level >= 7).length;
  
  // 计算今日待复习
  const now = Date.now();
  const dueToday = Object.values(appState.wordProgress).filter(w => 
    w.nextReview && w.nextReview <= now
  ).length;
  
  document.getElementById('total-words').textContent = total;
  document.getElementById('learned-words').textContent = learned;
  document.getElementById('mastered-words').textContent = mastered;
  document.getElementById('due-today').textContent = dueToday;
  document.getElementById('streak-count').textContent = appState.streak;
  
  const percent = total > 0 ? Math.round((learned / total) * 100) : 0;
  document.getElementById('progress-percent').textContent = percent + '%';
  document.getElementById('progress-fill').style.width = percent + '%';
}

// ==================== 学习模式 ====================
let learnQueue = [];
let learnIndex = 0;

function startLearning() {
  // 构建学习队列: 新词 + 待复习
  const now = Date.now();
  let newWords = [];
  let reviewWords = [];
  
  // 获取新词
  const learnedIds = new Set(Object.keys(appState.wordProgress));
  const availableNew = WORD_DATABASE.filter(w => !learnedIds.has(w.word));
  newWords = availableNew.sort((a,b) => b.freq - a.freq || Math.random() - 0.5).slice(0, appState.dailyGoal);
  
  // 获取待复习词
  Object.entries(appState.wordProgress).forEach(([wordId, progress]) => {
    if (progress.nextReview && progress.nextReview <= now) {
      const word = WORD_DATABASE.find(w => w.word === wordId);
      if (word) reviewWords.push(word);
    }
  });
  
  // 限制复习数量
  reviewWords = reviewWords.slice(0, appState.dailyReviewLimit);
  
  learnQueue = [...reviewWords, ...newWords];
  learnIndex = 0;
  
  if (learnQueue.length === 0) {
    showToast('🎉 今日学习任务已完成！');
    return;
  }
  
  switchPage('learn');
  showLearnWord();
}

function showLearnWord() {
  if (learnIndex >= learnQueue.length) {
    showToast('🎉 今日学习完成！');
    setTimeout(() => switchPage('home'), 1500);
    return;
  }
  
  const word = learnQueue[learnIndex];
  const card = document.getElementById('word-card');
  
  card.classList.remove('card-enter');
  void card.offsetWidth; // trigger reflow
  card.classList.add('card-enter');
  
  document.getElementById('learn-word').textContent = word.word;
  document.getElementById('learn-phonetic').textContent = word.phonetic;
  document.getElementById('learn-meaning').textContent = word.meaning;
  document.getElementById('learn-example').textContent = word.example;
  document.getElementById('learn-counter').textContent = `第 ${learnIndex + 1} / ${learnQueue.length} 个单词`;
  
  // 重置隐藏状态
  document.getElementById('learn-meaning').classList.add('word-hidden');
  document.getElementById('learn-example').classList.add('word-hidden');
  
  // 显示记忆曲线进度
  renderSchedule(word.word);
  
  // 自动发音
  if (appState.settings.pronunciation) {
    speakWord(word.word);
  }
}

function revealMeaning() {
  document.getElementById('learn-meaning').classList.remove('word-hidden');
  document.getElementById('learn-example').classList.remove('word-hidden');
}

function renderSchedule(wordId) {
  const container = document.getElementById('learn-schedule');
  const progress = appState.wordProgress[wordId];
  
  let html = '';
  EBBINGHAUS_INTERVALS.forEach((interval, i) => {
    let cls = 'schedule-dot';
    if (progress && progress.level > i) cls += ' completed';
    else if (progress && progress.level === i) cls += ' current';
    else cls += ' upcoming';
    html += `<div class="${cls}">${interval.label}</div>`;
  });
  container.innerHTML = html;
}

function rateWord(rating) {
  const word = learnQueue[learnIndex];
  const now = Date.now();
  
  if (!appState.wordProgress[word.word]) {
    appState.wordProgress[word.word] = { level: 0, nextReview: 0, history: [] };
  }
  
  const progress = appState.wordProgress[word.word];
  
  // 根据评分调整等级
  if (rating >= 3) {
    progress.level = Math.min(progress.level + 1, EBBINGHAUS_INTERVALS.length - 1);
  } else if (rating <= 1) {
    progress.level = Math.max(0, progress.level - 2);
  } else {
    progress.level = Math.max(0, progress.level - 1);
  }
  
  // 计算下次复习时间
  const intervalMinutes = EBBINGHAUS_INTERVALS[Math.min(progress.level, EBBINGHAUS_INTERVALS.length - 1)].minutes;
  progress.nextReview = now + intervalMinutes * 60 * 1000;
  progress.history.push({ time: now, rating });
  
  recordStudy();
  saveState();
  
  learnIndex++;
  showLearnWord();
}

// ==================== 默写模式 ====================
let dictationQueue = [];
let dictationIndex = 0;

function startDictation() {
  const learnedWords = Object.keys(appState.wordProgress).map(id => 
    WORD_DATABASE.find(w => w.word === id)
  ).filter(Boolean);
  
  if (learnedWords.length === 0) {
    showToast('请先学习一些单词！');
    return;
  }
  
  dictationQueue = learnedWords.sort(() => Math.random() - 0.5).slice(0, 20);
  dictationIndex = 0;
  switchPage('dictation');
  showDictationWord();
}

function showDictationWord() {
  if (dictationIndex >= dictationQueue.length) {
    showToast('🎉 默写完成！');
    setTimeout(() => switchPage('home'), 1500);
    return;
  }
  
  const word = dictationQueue[dictationIndex];
  document.getElementById('dict-meaning').textContent = word.meaning;
  document.getElementById('dict-phonetic').textContent = word.phonetic;
  document.getElementById('dict-input').value = '';
  document.getElementById('dict-input').className = 'dictation-input';
  document.getElementById('dict-feedback').textContent = '';
  document.getElementById('dictation-counter').textContent = `第 ${dictationIndex + 1} / ${dictationQueue.length} 个单词`;
  document.getElementById('dict-input').focus();
}

function checkDictation() {
  const input = document.getElementById('dict-input');
  const feedback = document.getElementById('dict-feedback');
  const correct = dictationQueue[dictationIndex].word.toLowerCase();
  const answer = input.value.trim().toLowerCase();
  
  if (answer === correct) {
    input.className = 'dictation-input correct';
    feedback.innerHTML = '<span style="color:var(--success)">✅ 正确！</span>';
    speakWord(correct);
  } else {
    input.className = 'dictation-input wrong';
    feedback.innerHTML = `<span style="color:var(--danger)">❌ 正确答案: <strong>${correct}</strong></span>`;
  }
}

function showDictHint() {
  const word = dictationQueue[dictationIndex].word;
  const hint = word[0] + '_'.repeat(word.length - 2) + word[word.length - 1];
  document.getElementById('dict-feedback').innerHTML = `<span style="color:var(--warning)">💡 提示: ${hint}</span>`;
}

function nextDictation() {
  dictationIndex++;
  showDictationWord();
}

// ==================== 词库管理 ====================
let currentCategory = 'all';

function renderCategoryTags() {
  const categories = ['all', ...new Set(WORD_DATABASE.map(w => w.category))];
  const container = document.getElementById('category-tags');
  
  container.innerHTML = categories.map(cat => 
    `<div class="category-tag ${cat === currentCategory ? 'active' : ''}" onclick="filterByCategory('${cat}')">
      ${cat === 'all' ? '全部' : cat}
    </div>`
  ).join('');
}

function filterByCategory(category) {
  currentCategory = category;
  renderCategoryTags();
  renderWordList();
}

function renderWordList() {
  const container = document.getElementById('word-list-container');
  let words = WORD_DATABASE;
  
  if (currentCategory !== 'all') {
    words = words.filter(w => w.category === currentCategory);
  }
  
  const searchTerm = document.getElementById('search-input')?.value?.toLowerCase() || '';
  if (searchTerm) {
    words = words.filter(w => 
      w.word.toLowerCase().includes(searchTerm) || 
      w.meaning.includes(searchTerm)
    );
  }
  
  if (words.length === 0) {
    container.innerHTML = `
      <div class="empty-state">
        <h3>没有找到匹配的单词</h3>
        <p>试试其他搜索词或分类</p>
      </div>`;
    return;
  }
  
  container.innerHTML = words.map(word => {
    const progress = appState.wordProgress[word.word];
    let masteryClass = 'mastery-new';
    let masteryText = '未学习';
    
    if (progress) {
      if (progress.level >= 7) { masteryClass = 'mastery-mastered'; masteryText = '已掌握'; }
      else if (progress.level >= 4) { masteryClass = 'mastery-familiar'; masteryText = '较熟悉'; }
      else { masteryClass = 'mastery-learning'; masteryText = '学习中'; }
    }
    
    return `
      <div class="word-list-item">
        <div class="word-list-info">
          <h3>${word.word} <span style="font-weight:400;font-size:13px;color:var(--subtext)">${word.phonetic}</span></h3>
          <p>${word.meaning}</p>
        </div>
        <span class="mastery-badge ${masteryClass}">${masteryText}</span>
      </div>`;
  }).join('');
}

function filterWords() {
  renderWordList();
}

// ==================== 设置 ====================
function toggleSetting(element) {
  element.classList.toggle('active');
  
  if (element.id === 'toggle-pronunciation') {
    appState.settings.pronunciation = element.classList.contains('active');
  } else if (element.id === 'toggle-auto-flip') {
    appState.settings.autoFlip = element.classList.contains('active');
  }
  
  saveState();
}

function exportData() {
  const dataStr = JSON.stringify(appState, null, 2);
  const blob = new Blob([dataStr], {type: 'application/json'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `vocab-backup-${new Date().toISOString().slice(0,10)}.json`;
  a.click();
  URL.revokeObjectURL(url);
  showToast('✅ 数据已导出');
}

function importData() {
  const input = document.createElement('input');
  input.type = 'file';
  input.accept = '.json';
  input.onchange = (e) => {
    const file = e.target.files[0];
    const reader = new FileReader();
    reader.onload = (event) => {
      try {
        const data = JSON.parse(event.target.result);
        appState = {...appState, ...data};
        saveState();
        renderHomePage();
        showToast('✅ 数据已导入');
      } catch(err) {
        showToast('❌ 导入失败，文件格式错误');
      }
    };
    reader.readAsText(file);
  };
  input.click();
}

function resetAll() {
  if (confirm('确定要重置所有学习进度吗？此操作不可撤销！')) {
    appState.wordProgress = {};
    appState.streak = 0;
    appState.lastStudyDate = null;
    saveState();
    renderHomePage();
    showToast('🔄 数据已重置');
  }
}

// ==================== 语音合成 ====================
function speakWord(word) {
  if ('speechSynthesis' in window) {
    const utterance = new SpeechSynthesisUtterance(word);
    utterance.lang = 'en-US';
    utterance.rate = 0.8;
    speechSynthesis.speak(utterance);
  }
}

// ==================== 键盘事件 ====================
document.addEventListener('keydown', (e) => {
  if (document.getElementById('page-dictation').classList.contains('active')) {
    if (e.key === 'Enter') {
      checkDictation();
    }
  }
});

// ==================== 启动应用 ====================
init();
